{
  "id": "ch-zuerich-plszh",
  "operator": "Stadt Zürich Parkleitsystem (PLS) — published as Open Data by the City of Zürich",
  "country": "CH",
  "canton": "ZH",
  "city": "Zürich",
  "website": "https://www.pls-zh.ch",
  "license": "CC0",
  "endpoints": [
    {
      "primary": true,
      "url": "https://www.pls-zh.ch/plsFeed/rss",
      "method": "GET",
      "format": "rss-xml",
      "auth": "none",
      "documented": true,
      "documentation_url": "https://data.stadt-zuerich.ch/dataset/parkleitsystem",
      "license": "CC0",
      "discovered_on": "https://data.stadt-zuerich.ch/dataset/parkleitsystem",
      "response_shape": "<rss><channel> with <item> elements per parking",
      "fields": {
        "channel/title": "feed title, e.g. \"FEED Parkleitsystem Stadt Zürich\"",
        "channel/copyright": "license notice (\"CC-0 License\")",
        "item/title": "parking name and address joined with \" / \", e.g. \"Parkhaus Accu / Otto-Schütz-Weg\"",
        "item/description": "status and free spaces in the form \"<state> /  <free>\", e.g. \"open /  156\"",
        "item/link": "detail page URL on pls-zh.ch",
        "item/pubDate": "RFC 822 timestamp of the latest update for this parking",
        "item/dc:date": "same as pubDate in ISO 8601"
      },
      "notes": "Official, CC0-licensed feed published by the City of Zürich. The RSS feed itself does NOT include total capacity — only free spaces. Title combines name and address with \" / \" as separator."
    },
    {
      "url": "https://api.parkendd.de/Zuerich",
      "method": "GET",
      "format": "json",
      "auth": "none",
      "documented": true,
      "documentation_url": "https://api.parkendd.de/",
      "cors": "Access-Control-Allow-Origin: * — usable directly from browser / frontend code",
      "discovered_on": "https://data.stadt-zuerich.ch/dataset/parkleitsystem (referenced by the official dataset page)",
      "response_shape": "{ last_downloaded, last_updated, lots: [ { name, id, lot_type, free, total, state, address, coords: { lat, lng } } ] }",
      "notes": "Third-party mirror that normalizes the official RSS feed into JSON with capacity, address and coordinates. Not the primary feed. State values: \"open\", \"closed\", \"nodata\". Some entries report total=0 (placeholder / unknown)."
    },
    {
      "url": "https://parkleitsystem.ch/wp-json/wp/v2/ht_parking?per_page=100&ht_parking_location_exclude%5B%5D=40",
      "method": "GET",
      "format": "json",
      "auth": "none",
      "documented": false,
      "discovered_on": "https://parkleitsystem.ch",
      "response_shape": "WordPress REST array; each item has id, slug, title, link, acf.google_maps { address, street_name, street_number, city, post_code, lat, lng }, acf.parkplaetze, acf.id_parkinghq",
      "notes": "Metadata only — no live free-space counts. Returns ~25 of the parkings shown on parkleitsystem.ch (a subset of the full PLS feed). The query parameter ht_parking_location_exclude=40 filters out a non-Zürich category. Useful for cross-referencing addresses, postal codes and slugs."
    },
    {
      "url": "https://parkleitsystem.ch/wp-content/themes/parkingzuerich/functions/api.php",
      "method": "GET",
      "format": "json",
      "auth": "none",
      "documented": false,
      "discovered_on": "https://parkleitsystem.ch (frontend XHR)",
      "notes": "Undocumented internal endpoint used by parkleitsystem.ch. Content-Type is text/html, no CORS — suitable for backend scripts, not browser code. Returns live free-space counts."
    }
  ],
